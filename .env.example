# ─── .env.example ─────────────────────────────────────────────────────────────
# THIS FILE IS COMMITTED TO GIT — contains no real credentials
# ──────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   Local   → copy to .env          → npm run test
#   QA      → copy to .env.qa       → npm run test:qa
#   Staging → copy to .env.staging  → npm run test:staging
# ──────────────────────────────────────────────────────────────────────────────

ENV=local
BASE_URL=https://automationexercise.com

TEST_USER_EMAIL=testuser@example.com
TEST_USER_PASSWORD=Test@12345

NEW_USER_NAME=Test User
NEW_USER_EMAIL=newuser@example.com
NEW_USER_PASSWORD=NewPass@123

API_TIMEOUT=10000
RETRY_COUNT=2
LOG_LEVEL=info
